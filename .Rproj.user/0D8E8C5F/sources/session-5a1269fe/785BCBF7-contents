```{r echo=FALSE, results='asis'}
A=survdiff(Surv(tempos,cens)~ventilator_support2, data=base)

B=logrank_test(Surv(tempos,cens)~factor(ventilator_support2),type="Peto-Peto", data = base)

format_p <- function(p) {
  if (p < 0.001) {
    "< 0.001"
  } else {
    sprintf("%.3f", p)
  }
}


cat(paste0(
  "<div style='text-align: center; font-size: 24px;'>",
  "<b>Teste Log-Rank:</b> p = ", format_p(A$pvalue), "<br><br>",
  "<b>Teste Peto-Peto:</b> p = ", format_p(pvalue(B)),
  "</div>"
))
```

