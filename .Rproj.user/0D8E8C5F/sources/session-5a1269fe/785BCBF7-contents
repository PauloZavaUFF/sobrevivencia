### Geral

```{r fig.align='center'}
ekm1<- survfit2(data=base,
                formula = Surv(tempos,cens)~1,
                conf.type = "log-log", 
                conf.int=0.95)


ggsurvfit(ekm1, linewidth = 1.2) +
  add_confidence_interval() +
  add_censor_mark(size = 2, alpha = 1)+
  add_risktable() +
  scale_ggsurvfit() +
  geom_hline(yintercept = 0.5, linetype = "dashed", color = "red")+
  add_quantile(y_value = 0.5)+
  labs(x = "Tempo (anos)",
       y = "Sobrevivência estimada") +
  theme_classic(base_size=16)
```

