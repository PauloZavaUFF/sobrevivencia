))

```



### Cirurgia anterior



```{r fig.align='center'}
ekm5<- survfit2(data=base,
                formula = Surv(tempos,cens)~previous_surgery2,
                conf.type = "log-log", 
                conf.int=0.95)


ggsurvfit(ekm5, linewidth = 1.2) +
  add_confidence_interval() +
  add_censor_mark(size = 2, alpha = 1)+
  add_risktable() +
  scale_ggsurvfit() +
  labs(x = "Tempo (anos)",
       y = "Sobrevivência estimada") +
  theme_classic(base_size=16)
```

```{r echo=FALSE, results='asis'}

A=survdiff(Surv(tempos,cens)~previous_surgery2, data=base)

B=logrank_test(Surv(tempos,cens)~factor(previous_surgery2),type="Peto-Peto", data = base)

cat(paste0(
  "<div style='text-align: center; font-size: 24px;'>",
  "<b>Teste Log-Rank:</b> p = ", format_p(A$pvalue), "<br><br>",
  "<b>Teste Peto-Peto:</b> p = ", format_p(pvalue(B)),
  "</div>"
))

```


:::

# Conclusão Não Paramétrica {data-background-image="Capa.png" style="text-align:center"}

## **Conclusão**

-   Aproximadamente **50% dos pacientes sobrevivem até cerca de 4 anos** após o transplante.

-   O uso de **ventilação mecânica** está associado a diferenças significativas na sobrevivência.

-   O uso de **suporte ECMO** também apresenta associação com a sobrevida dos pacientes.

-   A **incompatibilidade sanguínea** entre doador e receptor impacta negativamente a sobrevivência.

-   Não foram encontradas evidências de que **cirurgias prévias** influenciem significativamente a sobrevida.

# Estimação Paramétrica sem covariáveis {data-background-image="Capa.png" style="text-align:center"}



```{r echo=FALSE, warning=FALSE, message=FALSE}


ajuste_exp<-flexsurvreg(Surv(tempos, cens) ~ 1, dist = "exp", data=base)

ajuste_wei<-flexsurvreg(Surv(tempos, cens) ~ 1, dist = "weibull", data=base)

ajuste_lognorm<-flexsurvreg(Surv(tempos, cens) ~ 1, dist = "lnorm", data=base)

ajuste_gama<-flexsurvreg(Surv(tempos, cens) ~ 1, dist = "gamma", data=base)

ajuste_gengama<-flexsurvreg(Surv(tempos, cens) ~ 1, dist = "gengamma.orig", data=base)

```



## Modelos Paramétrica sem covariáveis

-   Para esta etapa, serão ajustados modelos paramétricos sem considerar variáveis explicativas (covariáveis).

-   Serão avaliados os modelos **Exponencial, Weibull, Log-Normal, Gama e Gama Generalizada**.

-   Para identificar o modelo com melhor ajuste aos dados, serão utilizados os seguintes métodos:

    -   Comparação gráfica com o estimador de Kaplan-Meier;

    -   Método da linearização;

    -   Critérios de informação AIC e BIC;

    -   Teste da Razão de Verossimilhanças (TRV).

## Ajuste dos modelos {.scrollable}

::: panel-tabset
### Exponencial

Na distribuição Exponencial, a densidade é determinada por um único parâmetro de taxa (α), que controla a velocidade de ocorrência dos eventos ao longo do tempo.



```{r echo=FALSE, results='asis'}

Mean_exp <- summary(ajuste_exp, type = "mean", cl = 0.95, se = TRUE)
Median_exp <- summary(ajuste_exp, type = "median", cl = 0.95, se = TRUE)

alpha <- round(ajuste_exp$res["rate","est"], 4)

cat(paste0(
  "<div style='text-align:center;'>",
  "<h2>Distribuição Exponencial</h2>",
  "<br>",
  "<table style='margin:auto; font-size:24px;'>",
  "<tr><td><b>α (Taxa)</b></td><td>", alpha, "</td></tr>",
  "<tr><td><b>Tempo Médio</b></td><td>", round(Mean_exp[[1]]$est,2), " anos</td></tr>",
  "<tr><td><b>Tempo Mediano</b></td><td>", round(Median_exp[[1]]$est,2), " anos</td></tr>",
  "</table>",
  "</div>"
))

```

```{r fig.align='center'}

plot(ajuste_exp,xlab="Tempos (Anos)",ylab = expression(hat(S)(t)))

plot(ajuste_exp,xlab="Tempos (Anos)",ylab = expression(hat(lambda)(t)),type="hazard")

plot(ajuste_exp,xlab="Tempos (Anos)",ylab = expression(hat(Lambda)(t)),type="cumhaz")

```



### Weibull

Na distribuição Weibull, a densidade é determinada pelos parâmetros de escala (κ) e forma (γ), que controlam, respectivamente, a escala temporal e o comportamento da taxa de ocorrência dos eventos.



```{r echo=FALSE, results='asis'}

Mean_wei <- summary(ajuste_wei, type = "mean", cl = 0.95, se = TRUE)
Median_wei <- summary(ajuste_wei, type = "median", cl = 0.95, se = TRUE)

kappa <- round(ajuste_wei$res["scale","est"], 4)
gamma <- round(ajuste_wei$res["shape","est"], 4)

cat(paste0(
  "<div style='text-align:center;'>",
  "<h2>Distribuição Weibull</h2>",
  "<br>",
  "<table style='margin:auto; font-size:24px;'>",
  "<tr><td><b>κ (Escala)</b></td><td>", kappa, "</td></tr>",
  "<tr><td><b>γ (Forma)</b></td><td>", gamma, "</td></tr>",
  "<tr><td><b>Tempo Médio</b></td><td>", round(Mean_wei[[1]]$est,2), " anos</td></tr>",
  "<tr><td><b>Tempo Mediano</b></td><td>", round(Median_wei[[1]]$est,2), " anos</td></tr>",
  "</table>",
  "</div>"
))

```

```{r fig.align='center'}

plot(ajuste_wei,xlab="Tempos (Anos)",ylab = expression(hat(S)(t)))

plot(ajuste_wei,xlab="Tempos (Anos)",ylab = expression(hat(lambda)(t)),type="hazard")

plot(ajuste_wei,xlab="Tempos (Anos)",ylab = expression(hat(Lambda)(t)),type="cumhaz")

```



### Log-Normal

Na distribuição Log-Normal, a densidade é determinada pelos parâmetros μ e σ, que controlam, respectivamente, a posição e a dispersão da distribuição na escala logarítmica.



```{r echo=FALSE, results='asis'}

Mean_lognorm <- summary(ajuste_lognorm, type = "mean", cl = 0.95, se = TRUE)
Median_lognorm <- summary(ajuste_lognorm, type = "median", cl = 0.95, se = TRUE)

mu <- round(ajuste_lognorm$res["meanlog","est"], 4)
sigma <- round(ajuste_lognorm$res["sdlog","est"], 4)

cat(paste0(
  "<div style='text-align:center;'>",
  "<h2>Distribuição Log-Normal</h2>",
  "<br>",
  "<table style='margin:auto; font-size:24px;'>",
  "<tr><td><b>μ (Posição)</b></td><td>", mu, "</td></tr>",
  "<tr><td><b>σ (Dispersão)</b></td><td>", sigma, "</td></tr>",
  "<tr><td><b>Tempo Médio</b></td><td>", round(Mean_lognorm[[1]]$est,2), " anos</td></tr>",
  "<tr><td><b>Tempo Mediano</b></td><td>", round(Median_lognorm[[1]]$est,2), " anos</td></tr>",
  "</table>",
  "</div>"
))

```

```{r fig.align='center'}

plot(ajuste_lognorm,xlab="Tempos (Anos)",ylab = expression(hat(S)(t)))

plot(ajuste_lognorm,xlab="Tempos (Anos)",ylab = expression(hat(lambda)(t)),type="hazard")

plot(ajuste_lognorm,xlab="Tempos (Anos)",ylab = expression(hat(Lambda)(t)),type="cumhaz")

```



### Gama

Na distribuição Gama, a densidade é determinada pelos parâmetros de forma (α) e taxa (β), responsáveis pelo formato da distribuição e pela velocidade de ocorrência dos eventos.



```{r echo=FALSE, results='asis'}

Mean_gama <- summary(ajuste_gama, type = "mean", cl = 0.95, se = TRUE)
Median_gama <- summary(ajuste_gama, type = "median", cl = 0.95, se = TRUE)

alpha <- round(ajuste_gama$res["shape","est"], 4)
beta <- round(ajuste_gama$res["rate","est"], 4)

cat(paste0(
  "<div style='text-align:center;'>",
  "<h2>Distribuição Gama</h2>",
  "<br>",
  "<table style='margin:auto; font-size:24px;'>",
  "<tr><td><b>α (Forma)</b></td><td>", alpha, "</td></tr>",
  "<tr><td><b>β (Taxa)</b></td><td>", beta, "</td></tr>",
  "<tr><td><b>Tempo Médio</b></td><td>", round(Mean_gama[[1]]$est,2), " anos</td></tr>",
  "<tr><td><b>Tempo Mediano</b></td><td>", round(Median_gama[[1]]$est,2), " anos</td></tr>",
  "</table>",
  "</div>"
))

```

```{r fig.align='center'}

plot(ajuste_gama,xlab="Tempos (Anos)",ylab = expression(hat(S)(t)))

plot(ajuste_gama,xlab="Tempos (Anos)",ylab = expression(hat(lambda)(t)),type="hazard")

plot(ajuste_gama,xlab="Tempos (Anos)",ylab = expression(hat(Lambda)(t)),type="cumhaz")

```



### Gama Generalizada

Na distribuição Gama Generalizada, a densidade é determinada pelos parâmetros de escala (a), forma (b) e forma adicional (k), que controlam a escala temporal e a flexibilidade do formato da distribuição.



```{r echo=FALSE, results='asis'}

Mean_gengama <- summary(ajuste_gengama, type = "mean", cl = 0.95, se = TRUE)
Median_gengama <- summary(ajuste_gengama, type = "median", cl = 0.95, se = TRUE)

a <- round(ajuste_gengama$res["scale","est"], 4)
b <- round(ajuste_gengama$res["shape","est"], 4)
k <- round(ajuste_gengama$res["k","est"], 4)

cat(paste0(
  "<div style='text-align:center;'>",
  "<h2>Distribuição Gama Generalizada</h2>",
  "<br>",
  "<table style='margin:auto; font-size:24px;'>",
  "<tr><td><b>a (Escala)</b></td><td>", a, "</td></tr>",
  "<tr><td><b>b (Forma)</b></td><td>", b, "</td></tr>",
  "<tr><td><b>k (Forma adicional)</b></td><td>", k, "</td></tr>",
  "<tr><td><b>Tempo Médio</b></td><td>", round(Mean_gengama[[1]]$est,2), " anos</td></tr>",
  "<tr><td><b>Tempo Mediano</b></td><td>", round(Median_gengama[[1]]$est,2), " anos</td></tr>",
  "</table>",
  "</div>"
))

```

```{r fig.align='center'}

plot(ajuste_gengama,xlab="Tempos (Anos)",ylab = expression(hat(S)(t)))

plot(ajuste_gengama,xlab="Tempos (Anos)",ylab = expression(hat(lambda)(t)),type="hazard")

plot(ajuste_gengama,xlab="Tempos (Anos)",ylab = expression(hat(Lambda)(t)),type="cumhaz")

```



### Comparação das curvas



```{r fig.align='center'}

plot(ajuste_exp,xlab="Tempos (meses)",ylab = expression(hat(S)(t)),lwd.ci=0, lty.ci=0, col="red")
lines(ajuste_wei,lwd.ci=0, lty.ci=0, col="blue")
lines(ajuste_lognorm,lwd.ci=0, lty.ci=0, col="green")
