## Comparação de Curvas {.scrollable}



```{r}
base= base |> 
  rename(tempos=observed_time_years,
         cens=event)

base <- base |>
  mutate(
    ventilator_support2 = factor(
      ventilator_support,
      levels = c(0, 1),
      labels = c("Não", "Sim")
    ),
    ecmo_support2=factor(
      ecmo_support,
      levels = c(0, 1),
      labels = c("Não", "Sim")
    ),
    donor_recipient_blood_mismatch2 = factor(
      donor_recipient_blood_mismatch,
      levels = c(0, 1),
      labels = c("Compatível", "Incompatívo")
    ),
    previous_surgery2= factor(
      previous_surgery,
      levels = c(0, 1),
      labels = c("Não", "Sim")
    )
  )
```



::: panel-tabset
### Geral



```{r fig.align='center'}
ekm1<- survfit2(data=base,
                formula = Surv(tempos,cens)~1,
                conf.type = "log-log", 
                conf.int=0.95)


ggsurvfit(ekm1, linewidth = 1.2) +
  add_confidence_interval() +
  add_censor_mark(size = 2, alpha = 1)+
  add_risktable() +
  scale_ggsurvfit() +
  geom_hline(yintercept = 0.5, linetype = "dashed", color = "red")+
  add_quantile(y_value = 0.5)+
  labs(x = "Tempo (anos)",
       y = "Sobrevivência estimada") +
  theme_classic(base_size=16)
```



### Ventilação Mecânica



```{r fig.align='center'}
ekm2<- survfit2(data=base,
                formula = Surv(tempos,cens)~ventilator_support2,
                conf.type = "log-log", 
                conf.int=0.95)


ggsurvfit(ekm2, linewidth = 1.2) +
  add_confidence_interval() +
  add_censor_mark(size = 2, alpha = 1)+
  add_risktable() +
  scale_ggsurvfit() +
  labs(x = "Tempo (anos)",
       y = "Sobrevivência estimada") +
  theme_classic(base_size=16)
```

```{r echo=FALSE, results='asis'}
A=survdiff(Surv(tempos,cens)~ventilator_support2, data=base)

B=logrank_test(Surv(tempos,cens)~factor(ventilator_support2),type="Peto-Peto", data = base)

format_p <- function(p) {
  if (p < 0.001) {
    "< 0.001"
  } else {
    sprintf("%.3f", p)
  }
}


cat(paste0(
  "<div style='text-align: center; font-size: 24px;'>",
  "<b>Teste Log-Rank:</b> p = ", format_p(A$pvalue), "<br><br>",
  "<b>Teste Peto-Peto:</b> p = ", format_p(pvalue(B)),
  "</div>"
))
```



### Suporte ECM0



```{r fig.align='center'}
ekm3<- survfit2(data=base,
                formula = Surv(tempos,cens)~ecmo_support2,
                conf.type = "log-log", 
