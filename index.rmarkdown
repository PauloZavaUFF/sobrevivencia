## Comparação dos Modelos {.scrollable}

::: panel-tabset
### Método gráfico via Kaplan-Meier



```{r fig.align='center'}

ekm <- survfit(Surv(tempos,cens)~1, data=base)
Surv_ekm <- data.frame(ekm$time,ekm$surv)
colnames(Surv_ekm) <- c("Tempo", "Surv_EKM")

#MÉTODO GRÁFICO: KAPLAN-MEIER
Surv_pam <- data.frame(summary(ajuste_exp)[[1]][,c(1,2)],
                       summary(ajuste_wei)[[1]][,2],
                       summary(ajuste_lognorm)[[1]][,2],
                       summary(ajuste_gama)[[1]][,2],
                       summary(ajuste_gengama)[[1]][,2])
colnames(Surv_pam) <- c("Tempo", "Surv_exp", "Surv_wei", "Surv_lognorm", "Surv_gama", "Surv_gengama")


Surv_Final <- merge(Surv_pam,Surv_ekm,by="Tempo",all.x=T)


par(mfrow=c(2,3))
plot(Surv_Final$Surv_EKM, Surv_Final$Surv_exp, 
     xlab= "S(t): Kaplan-Meier", ylab = "S(t): Exponencial")
lines(c(0,1), c(0,1), type="l", lty=1)
plot(Surv_Final$Surv_EKM, Surv_Final$Surv_wei, 
     xlab= "S(t): Kaplan-Meier", ylab = "S(t): Weibull" )
lines(c(0,1), c(0,1), type="l", lty=1)
plot(Surv_Final$Surv_EKM, Surv_Final$Surv_lognorm, 
     xlab= "S(t): Kaplan-Meier", ylab = "S(t): LogNormal")
lines(c(0,1), c(0,1), type="l", lty=1)
plot(Surv_Final$Surv_EKM, Surv_Final$Surv_gama, 
     xlab= "S(t): Kaplan-Meier", ylab = "S(t): Gama" )
lines(c(0,1), c(0,1), type="l", lty=1)
plot(Surv_Final$Surv_EKM, Surv_Final$Surv_gengama, 
     xlab= "S(t): Kaplan-Meier", ylab = "S(t): Gama Generalizada" )
lines(c(0,1), c(0,1), type="l", lty=1)

```



### Método da linearização



```{r fig.align='center'}
EixoY_exp = -log(Surv_ekm$Surv_EKM)
EixoX_exp = Surv_ekm$Tempo

EixoY_wei = log(-log(Surv_ekm$Surv_EKM))
EixoX_wei = log(Surv_ekm$Tempo)

EixoY_lognorm = qnorm(Surv_ekm$Surv_EKM)
EixoX_lognorm = log(Surv_ekm$Tempo)

par(mfrow=c(1,3))
plot(EixoX_exp, EixoY_exp, 
     xlab = "t",
     ylab = expression(log(S(t))),
     main = "Exponencial")
plot(EixoX_wei, EixoY_wei,
     xlab = expression(log(t)),
     ylab = expression(log(-log(S(t)))),
     main = "Weibull")
plot(EixoX_lognorm, EixoY_lognorm,
     xlab = expression(log(t)),
     ylab = expression(Phi^{-1}(S(t))),
     main = "Log-Normal")

```



### Critérios de informação AIC e BIC



```{r echo=FALSE, results='asis'}

Comparacao <- data.frame(
  Modelo = c(
    "Exponencial",
    "Weibull",
    "Log-Normal",
    "Gama",
    "Gama Generalizada"
  ),
  AIC = round(c(
    ajuste_exp$AIC,
    ajuste_wei$AIC,
    ajuste_lognorm$AIC,
    ajuste_gama$AIC,
    ajuste_gengama$AIC
  ), 2),
  BIC = round(c(
    ajuste_exp$BIC,
    ajuste_wei$BIC,
    ajuste_lognorm$BIC,
    ajuste_gama$BIC,
    ajuste_gengama$BIC
  ), 2)
)

kable(
  Comparacao,
  col.names = c("Modelo", "AIC", "BIC"),
  align = c("l", "c", "c"),
  digits = 2,
  caption = "Comparação dos modelos pelos critérios de informação"
)


```



### Teste da Razão de Verossimilhanças (TRV)



```{r echo=FALSE, results='asis'}

format_p <- function(p) {
  ifelse(p < 0.001, "<0.001", sprintf("%.4f", p))
}

TRV_exp = 2*(ajuste_gengama$loglik-ajuste_exp$loglik)
P_valor_exp = pchisq(TRV_exp,2,lower.tail=F)
TRV_wei = 2*(ajuste_gengama$loglik-ajuste_wei$loglik)
P_valor_wei = pchisq(TRV_wei,1,lower.tail=F)
TRV_lognorm = 2*(ajuste_gengama$loglik-ajuste_lognorm$loglik)
P_valor_lognorm = pchisq(TRV_lognorm,1,lower.tail=F)
TRV_gama = 2*(ajuste_gengama$loglik-ajuste_gama$loglik)
P_valor_gama = pchisq(TRV_gama,1,lower.tail=F)

Comparacao_TRV <- data.frame(
  Modelo = c(
    "Exponencial",
    "Weibull",
    "Log-Normal",
    "Gama"
  ),
  TRV = round(c(
    TRV_exp,
    TRV_wei,
    TRV_lognorm,
    TRV_gama
  ), 2),
  `p-valor` = format_p(c(
    P_valor_exp,
    P_valor_wei,
    P_valor_lognorm,
    P_valor_gama
  ))
)

kable(
  Comparacao_TRV,
  align = c("l", "c", "c"),
  caption = "Comparação dos modelos via TRV (referência: Gama Generalizada)"
)
```


:::

## Resultado {.scrollable}

Entre os modelos avaliados, a distribuição Gama Generalizada apresentou o melhor desempenho. Esse resultado foi evidenciado pela boa aderência visual à curva de Kaplan-Meier, pelos menores valores dos critérios de informação AIC e BIC e pelos resultados do Teste da Razão de Verossimilhanças, que não indicaram evidências de que modelos mais simples apresentassem ajuste equivalente aos dados.



```{r fig.align='center'}

t <- seq(min(base$tempos), max(base$tempos), length.out = 100)

S <- summary(ajuste_gengama, t = t, type = "survival")[[1]]
h <- summary(ajuste_gengama, t = t, type = "hazard")[[1]]
H <- summary(ajuste_gengama, t = t, type = "cumhaz")[[1]]

df <- rbind(
  data.frame(t = t, valor = S$est, li = S$lcl, ls = S$ucl, funcao = "S(t)"),
  data.frame(t = t, valor = h$est, li = h$lcl, ls = h$ucl, funcao = "h(t)"),
  data.frame(t = t, valor = H$est, li = H$lcl, ls = H$ucl, funcao = "H(t)")
)

df$funcao <- factor(
  df$funcao,
  levels = c("S(t)", "h(t)", "H(t)"),
  labels = c("S(t)", "lambda(t)", "Lambda(t)")
)


ggplot(df, aes(t, valor, color = funcao, fill = funcao)) +
  geom_ribbon(aes(ymin = li, ymax = ls), alpha = 0.2, color = NA) +
  geom_line(size = 1.1) +
  facet_wrap(~funcao, scales = "free_y", labeller = label_parsed) +
  labs(x = "Tempo", y = NULL,
       title = "Funções do Modelo Gama Generalizado") +
  theme_bw(base_size = 14) +
  theme(legend.position = "none")


```

```{r echo=FALSE, results='asis'}

Mean_gengama <- summary(ajuste_gengama, type = "mean", cl = 0.95, se = TRUE)
Median_gengama <- summary(ajuste_gengama, type = "median", cl = 0.95, se = TRUE)

a <- round(ajuste_gengama$res["scale","est"], 4)
b <- round(ajuste_gengama$res["shape","est"], 4)
k <- round(ajuste_gengama$res["k","est"], 4)

cat(paste0(
  "<div style='text-align:center;'>",
  "<h2>Distribuição Gama Generalizada</h2>",
  "<br>",
  "<table style='margin:auto; font-size:24px;'>",
  "<tr><td><b>a (Escala)</b></td><td>", a, "</td></tr>",
  "<tr><td><b>b (Forma)</b></td><td>", b, "</td></tr>",
  "<tr><td><b>k (Forma adicional)</b></td><td>", k, "</td></tr>",
  "<tr><td><b>Tempo Médio</b></td><td>", round(Mean_gengama[[1]]$est,2), " anos</td></tr>",
  "<tr><td><b>Tempo Mediano</b></td><td>", round(Median_gengama[[1]]$est,2), " anos</td></tr>",
  "</table>",
  "</div>"
))

```



# Estimação Paramétrica com covariáveis {data-background-image="Capa.png" style="text-align:center"}

## Escolha das covariáveis {.scrollable}

::: panel-tabset
### Passo a passo

Antes de fazer o passo a passo primeiro fazemos um filtro inicial nas variavies qualitativa, tiramos as que tiveram Teste de peto-peto e Log-Rank falou que não possuem diferença entre os grupos

-   Passo 1 – Seleção Inicial, ajustar modelos com uma covariável por vez e o modelo nulo. Aplicar o Teste da Razão de Verossimilhanças (TRV);

-   Passo 2 – Modelo Múltiplo Inicial, ajustar um modelo com todas as covariáveis selecionadas. Remover uma covariável por vez;

-   Passo 3 – Reavaliação das Exclusões, ajustar o modelo com as covariáveis retidas. Reintroduzir, individualmente, as covariáveis excluídas no Passo 2;

-   Passo 4 – Reavaliação das Variáveis Iniciais. ajustar o modelo obtido no Passo 3. Testar novamente as covariáveis descartadas no Passo 1.

-   Passo 5 – Avaliação de Interações, ajustar o modelo final de efeitos principais. Testar interações duplas entre as covariáveis selecionadas;

### Processo

-   A variável que indicava se o paciente havia sido submetido a cirurgia previamente foi removida no filtro inicial.

-   A variável creatinine foi removida na primeira etapa.

-   Não houve remoção de variáveis na etapa 2.

-   Não foram adicionadas variáveis na etapa 3.

-   Não foram adicionadas variáveis na etapa 4.

-   Nenhuma interação entre variáveis foi selecionada para o modelo final.

### Variáveis do modelo final

As variáveis selecionadas ao final do processo foram:

-   recipient_age

-   weight_kg

-   bilirubin

-   ventilator_support

-   ecmo_support

-   donor_recipient_blood_mismatch

-   ischemic_time_hours

-   donor_age

-   recipient_age_c

-   donor_age_c

-   weight_kg_c
:::

## Seleção do modelo final {.scrollable}



```{r}
ajuste_gengama <- flexsurvreg(
  data = base,
  Surv(tempos, cens) ~ recipient_age + weight_kg + bilirubin +
    ventilator_support + ecmo_support +
    donor_recipient_blood_mismatch +
    ischemic_time_hours + donor_age ,
  dist = "gengamma"
)

ajuste_exp <- flexsurvreg(
  data = base,
  Surv(tempos, cens) ~ recipient_age + weight_kg + bilirubin +
    ventilator_support + ecmo_support +
    donor_recipient_blood_mismatch +
    ischemic_time_hours + donor_age ,
  dist = "exponential"
)

ajuste_wei <- flexsurvreg(
  data = base,
  Surv(tempos, cens) ~ recipient_age + weight_kg + bilirubin +
    ventilator_support + ecmo_support +
    donor_recipient_blood_mismatch +
    ischemic_time_hours + donor_age ,
  dist = "weibull"
)

ajuste_lognorm <- flexsurvreg(
  data = base,
  Surv(tempos, cens) ~ recipient_age + weight_kg + bilirubin +
    ventilator_support + ecmo_support +
    donor_recipient_blood_mismatch +
    ischemic_time_hours + donor_age ,
  dist = "lnorm"
)

ajuste_gama <- flexsurvreg(
  data = base,
  Surv(tempos, cens) ~ recipient_age + weight_kg + bilirubin +
    ventilator_support + ecmo_support +
    donor_recipient_blood_mismatch +
    ischemic_time_hours + donor_age ,
  dist = "gamma"
)
```



::: panel-tabset
### AIC e BIC



```{r}
Comparacao <- rbind(
  c(ajuste_gengama$AIC, ajuste_gengama$BIC),
  c(ajuste_exp$AIC, ajuste_exp$BIC),
  c(ajuste_wei$AIC, ajuste_wei$BIC),
  c(ajuste_lognorm$AIC, ajuste_lognorm$BIC),
  c(ajuste_gama$AIC, ajuste_gama$BIC)
)

rownames(Comparacao) <- c(
  "Gama Generalizada",
  "Exponencial",
  "Weibull",
  "LogNormal",
  "Gama"
)

colnames(Comparacao) <- c("AIC", "BIC")

knitr::kable(
  Comparacao,
  align = c("l", "c", "c"),
  caption = "Comparação dos modelos paramétricos via AIC e BIC (modelo final)"
)
```



### TRV



```{r}
TRV_exp <- 2 * (ajuste_gengama$loglik - ajuste_exp$loglik)
P_valor_exp <- pchisq(TRV_exp, df = 2, lower.tail = FALSE)

TRV_wei <- 2 * (ajuste_gengama$loglik - ajuste_wei$loglik)
P_valor_wei <- pchisq(TRV_wei, df = 1, lower.tail = FALSE)

TRV_lognorm <- 2 * (ajuste_gengama$loglik - ajuste_lognorm$loglik)
P_valor_lognorm <- pchisq(TRV_lognorm, df = 1, lower.tail = FALSE)

TRV_gama <- 2 * (ajuste_gengama$loglik - ajuste_gama$loglik)
P_valor_gama <- pchisq(TRV_gama, df = 1, lower.tail = FALSE)

TRV <- data.frame(
  Comparacao = c(
    "Exponencial x Gama Generalizada",
    "Weibull x Gama Generalizada",
    "LogNormal x Gama Generalizada",
    "Gama x Gama Generalizada"
  ),
  TRV = c(TRV_exp, TRV_wei, TRV_lognorm, TRV_gama),
  P_valor = c(P_valor_exp, P_valor_wei, P_valor_lognorm, P_valor_gama)
)

knitr::kable(
  TRV,
  align = c("l", "c", "c"),
  caption = "Teste da Razão de Verossimilhança (TRV) comparando modelos ao Gama Generalizada"
)
```


:::

## Modelo Final {.scrollable}

::: panel-tabset
### Modelo

Temos, portanto, o seguinte modelo final ajustado.

O tempo de sobrevivência $T$ segue uma Distribuição Gama Generalizada (GG):

$$T \sim GG(\mu,\sigma,Q)$$

$$
\begin{aligned}
\mu = \beta_0
&+ \beta_1 \cdot recipient\_age
+ \beta_2 \cdot weight\_kg
+ \beta_3 \cdot bilirubin
+ \beta_4 \cdot ventilator\_support \\
&+ \beta_5 \cdot ecmo\_support
+ \beta_6 \cdot donor\_recipient\_blood\_mismatch
+ \beta_7 \cdot ischemic\_time\_hours \\
&+ \beta_8 \cdot donor\_age
+ \beta_9 \cdot recipient\_age\_c
+ \beta_{10} \cdot donor\_age\_c
+ \beta_{11} \cdot weight\_kg\_c
\end{aligned}
$$

Os parâmetros adicionais do modelo são dados por:
$$ \sigma =0.6486$$
$$Q = 0.3746$$
O vetor de $\beta_i$ está descrito na tabela abaixo:



```{r echo=FALSE, results='asis'}

library(broom)

Tabela_gengama <- tidy(ajuste_gengama)
Tabela_gengama = Tabela_gengama[-c(2:3),]

knitr::kable(
  Tabela_gengama,
  digits = 4,
  align = c("l", "c", "c", "c", "c"),
  caption = "Coeficientes do modelo Gama Generalizada"
)
```

```{r fig.align='center'}

t <- seq(min(base$tempos), max(base$tempos), length.out = 100)

S <- summary(ajuste_gengama, t = t, type = "survival")[[1]]
h <- summary(ajuste_gengama, t = t, type = "hazard")[[1]]
H <- summary(ajuste_gengama, t = t, type = "cumhaz")[[1]]

df <- rbind(
  data.frame(t = t, valor = S$est, li = S$lcl, ls = S$ucl, funcao = "S(t)"),
  data.frame(t = t, valor = h$est, li = h$lcl, ls = h$ucl, funcao = "h(t)"),
  data.frame(t = t, valor = H$est, li = H$lcl, ls = H$ucl, funcao = "H(t)")
)

df$funcao <- factor(
  df$funcao,
  levels = c("S(t)", "h(t)", "H(t)"),
  labels = c("S(t)", "lambda(t)", "Lambda(t)")
)


ggplot(df, aes(t, valor, color = funcao, fill = funcao)) +
  geom_ribbon(aes(ymin = li, ymax = ls), alpha = 0.2, color = NA) +
  geom_line(size = 1.1) +
  facet_wrap(~funcao, scales = "free_y", labeller = label_parsed) +
  labs(x = "Tempo", y = NULL,
       title = "Funções do Modelo Gama Generalizado") +
  theme_bw(base_size = 14) +
  theme(legend.position = "none")


```

```{r echo=FALSE, results='asis'}

library(broom)

Tabela_gengama <- tidy(ajuste_gengama)

knitr::kable(
  Tabela_gengama,
  digits = 4,
  align = c("l", "c", "c", "c", "c"),
  caption = "Coeficientes do modelo Gama Generalizada"
)
```



### Resíduos



```{r fig.align='center'}

ResiduoCS = coxsnell_flexsurvreg(ajuste_gengama)$est
par(mfrow=c(1,2))
ekm<- survfit (Surv(ResiduoCS,base$cens)~1,type="kaplan-meier")
plot(ekm, fun="cumhaz",xlab="Resíduos de Cox-Snell",ylab="Função de risco acumulado")
abline(0, 1, col="red")

plot(ekm, xlab="Resíduos de Cox-Snell",ylab="Função de sobrevivência")
ResiduoCS<-sort(ResiduoCS)
exp1<-exp(-ResiduoCS)
points(ResiduoCS,exp1, col="red",type="l")



